{
  "manifest_version": 3,
  "name": "Sleek Note Taker",
  "version": "1.0.0",
  "description": "A completely safe extension to take notes in your browser.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
